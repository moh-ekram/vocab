rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'mohammad.001ekram@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- ENTITY VALIDATION BLUEPRINTS (Pillar 2) ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256
        && (data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 128))
        && (data.updatedAt == null || (data.updatedAt is string && data.updatedAt.size() <= 128))
        && (data.activeCourseId == null || (data.activeCourseId is string && data.activeCourseId.size() <= 128))
        && (data.quizScore == null || data.quizScore is int)
        && (data.quizTaken == null || data.quizTaken is int)
        && (data.folders == null || data.folders is list)
        && (data.enrolledCourseIds == null || data.enrolledCourseIds is list)
        && (data.progress == null || data.progress is map)
        && (data.settings == null || data.settings is map)
        && (data.goal == null || data.goal is map)
        && (data.synonymProgress == null || data.synonymProgress is map);
    }

    function isValidCourse(data) {
      return data.title is string && data.title.size() <= 256
        && (data.description == null || (data.description is string && data.description.size() <= 1024))
        && (data.totalGroups == null || data.totalGroups is int)
        && (data.words == null || data.words is list)
        && (data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 128))
        && (data.createdBy == null || (data.createdBy is string && data.createdBy.size() <= 256));
    }

    // --- COLLECTION RULES ---

    // 1. Users Profiles Collection
    match /users/{userId} {
      // Allow single document get only if it's the owner or admin (PII Isolation - Pillar 6)
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow collection listing for signed-in users (to load Leaderboard/Admin)
      allow list: if isSignedIn();

      // Create new profile: must be the authenticated owner registering their own email (Pillar 2)
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email == request.auth.token.email;

      // Update profile: can only be done by owner or admin (Pillar 4)
      allow update: if (isOwner(userId) || isAdmin())
        && isValidId(userId)
        && isValidUser(request.resource.data)
        // Immutability Guards (Pillar 12)
        && (request.resource.data.createdAt == null || resource.data.createdAt == null || request.resource.data.createdAt == resource.data.createdAt)
        && (request.resource.data.email == null || resource.data.email == null || request.resource.data.email == resource.data.email)
        // strict field changes (Pillar 4 & 5)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'progress', 'folders', 'goal', 'synonymProgress', 'settings',
             'enrolledCourseIds', 'activeCourseId', 'quizScore', 'quizTaken',
             'updatedAt'
           ]);

      // Only the admin can delete a user document
      allow delete: if isAdmin();
    }

    // 2. Courses Collection
    match /courses/{courseId} {
      allow read: if true; // Publicly accessible so visitors can preview courses

      allow create: if isAdmin()
        && isValidId(courseId)
        && isValidCourse(request.resource.data);

      allow update: if isAdmin()
        && isValidId(courseId)
        && isValidCourse(request.resource.data);

      allow delete: if isAdmin();
    }
  }
}
