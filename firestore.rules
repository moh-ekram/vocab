rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() 
        && request.auth.token != null 
        && request.auth.token.email != null 
        && (
          request.auth.token.email == 'mohammad.001ekram@gmail.com'
          || request.auth.token.email.matches('(?i)^mohammad\\.001ekram@gmail\\.com$')
        );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // --- ENTITY VALIDATION BLUEPRINTS (Pillar 2) ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256
        && (data.get('createdAt', null) == null || (data.createdAt is string && data.createdAt.size() <= 128))
        && (data.get('updatedAt', null) == null || (data.updatedAt is string && data.updatedAt.size() <= 128))
        && (data.get('activeCourseId', null) == null || (data.activeCourseId is string && data.activeCourseId.size() <= 128))
        && (data.get('quizScore', null) == null || data.quizScore is int)
        && (data.get('quizTaken', null) == null || data.quizTaken is int)
        && (data.get('folders', null) == null || data.folders is list)
        && (data.get('enrolledCourseIds', null) == null || data.enrolledCourseIds is list)
        && (data.get('progress', null) == null || data.progress is map)
        && (data.get('settings', null) == null || data.settings is map)
        && (data.get('goal', null) == null || data.goal is map)
        && (data.get('synonymProgress', null) == null || data.synonymProgress is map)
        && (data.get('blankProgress', null) == null || data.blankProgress is map)
        && (data.get('oooProgress', null) == null || data.oooProgress is map)
        && (data.get('analogyProgress', null) == null || data.analogyProgress is map);
    }

    function isValidCourse(data) {
      return data.title is string && data.title.size() <= 1000
        && (data.get('description', null) == null || (data.description is string && data.description.size() <= 10000))
        && (data.get('totalGroups', null) == null || data.totalGroups is int || data.totalGroups is float)
        && (data.get('words', null) == null || data.words is list)
        && (data.get('createdAt', null) == null || (data.createdAt is string && data.createdAt.size() <= 128))
        && (data.get('createdBy', null) == null || (data.createdBy is string && data.createdBy.size() <= 256))
        && (data.get('isDefault', null) == null || data.isDefault is bool)
        && (data.get('isRestricted', null) == null || data.isRestricted is bool)
        && (data.get('allowedUsers', null) == null || data.allowedUsers is list)
        && (data.get('variableToggles', null) == null || data.variableToggles is map)
        && (data.get('price', null) == null || data.price is int || data.price is float)
        && (data.get('bkashNumber', null) == null || (data.bkashNumber is string && data.bkashNumber.size() <= 64))
        && (data.get('verifiedPayments', null) == null || data.verifiedPayments is list)
        && (data.get('placeLabels', null) == null || data.placeLabels is map)
        && (data.get('allowedUsersExpiry', null) == null || data.allowedUsersExpiry is map)
        && (data.get('enabledGames', null) == null || data.enabledGames is map);
    }

    function isValidAccessRequest(data) {
      return data.courseId is string && data.courseId.size() <= 128
        && (data.get('courseTitle', null) == null || (data.courseTitle is string && data.courseTitle.size() <= 1000))
        && data.bkashNumber is string && data.bkashNumber.size() <= 64
        && data.email is string && data.email.size() <= 256
        && data.trxId is string && data.trxId.size() <= 128
        && data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected')
        && (data.get('price', null) == null || data.price is int || data.price is float)
        && (data.createdAt is string && data.createdAt.size() <= 128)
        && (data.get('requestedBy', null) == null || (data.requestedBy is string && data.requestedBy.size() <= 256));
    }

    // --- COLLECTION RULES ---

    // 1. Users Profiles Collection
    match /users/{userId} {
      // Allow single document get only if it's the owner or admin (PII Isolation - Pillar 6)
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow collection listing for signed-in users (to load Leaderboard/Admin)
      allow list: if isSignedIn();

      // Create new profile: must be the authenticated owner registering their own email (Pillar 2)
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email == request.auth.token.email;

      // Update profile: can only be done by owner or admin (Pillar 4)
      allow update: if (isOwner(userId) || isAdmin())
        && isValidId(userId)
        && isValidUser(request.resource.data)
        // Immutability Guards (Pillar 12)
        && (request.resource.data.createdAt == null || resource.data.createdAt == null || request.resource.data.createdAt == resource.data.createdAt)
        && (request.resource.data.email == null || resource.data.email == null || request.resource.data.email == resource.data.email)
        // strict field changes (Pillar 4 & 5)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'progress', 'folders', 'goal', 'synonymProgress', 'blankProgress', 'oooProgress', 'analogyProgress', 'settings',
             'enrolledCourseIds', 'activeCourseId', 'quizScore', 'quizTaken',
             'updatedAt'
           ]);

      // Only the admin can delete a user document
      allow delete: if isAdmin();
    }

    // 2. Courses Collection
    match /courses/{courseId} {
      allow read: if true; // Publicly accessible so visitors can preview courses

      allow create: if isAdmin()
        && isValidId(courseId)
        && isValidCourse(request.resource.data);

      allow update: if isAdmin()
        && isValidId(courseId)
        && isValidCourse(request.resource.data);

      allow delete: if isAdmin();
    }

    // 3. Reports Collection
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 4. Access Requests Collection
    match /access_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.requestedBy == request.auth.token.email));
      
      allow create: if isSignedIn()
        && isValidId(requestId)
        && isValidAccessRequest(request.resource.data)
        && request.resource.data.status == 'pending';

      allow update: if isAdmin()
        && isValidId(requestId)
        && isValidAccessRequest(request.resource.data);

      allow delete: if isAdmin();
    }

    // 5. Blank Questions Collection
    match /blank_questions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 6. Odd One Out Questions Collection
    match /odd_one_out_questions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 7. Word Analogy Questions Collection
    match /word_analogy_questions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
