rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email == 'mohammad.001ekram@gmail.com' && request.auth.token.email_verified == true;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && request.auth.token.email == 'mohammad.001ekram@gmail.com' && request.auth.token.email_verified == true;
      }
    }
  }
}
